{
  "name": "url-shortener",
  "private": true,
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "prepare": "husky install"
  },
  "devDependencies": {
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^8.0.0",
    "prettier": "^3.8.3"
  },
  "dependencies": {
    "@nestjs/config": "^4.0.4",
    "lint-staged": "^17.0.5"
  },
  "lint-staged": {
    "backend/**/*.{ts,tsx}": [
      "pnpm --filter backend exec eslint --fix"
    ],
    "frontend/**/*.{ts,tsx}": [
      "pnpm --filter frontend exec eslint --fix"
    ]
  }
}
